{
    "layer": "top",
    // "margin-top": 14,
    "margin-bottom": 0,
    "layer": "top",
    "margin-left": 0,
    "margin-right": 0,    
    "spacing": 0,

    // Modules Definition.
    "modules-left": [
      "custom/appmenu",
      "wlr/taskbar",
      "group/quicklinks",
      "hyprland/window"
     ],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [
      "pulseaudio",
      "bluetooth",
      "battery",
      "network",
      // "group/hardware",
      "custom/cliphist",
      "idle_inhibitor",
      "tray",
      "clock",
      "custom/exit"
     ],

    // Modules configuration
    "custom/appmenu": {
        "format": "Apps",
        "on-click": "wofi --show drun -a -I",
        "tooltip": false
    },
    "hyprland/workspaces" : {
        // "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "format": "{}",
        "format-icons": {
          "urgent": "’ü¬",
          "focused": "’åÆ",
          "default": "’äæ"
        },
        "persistent-workspaces": {
          "*": 5
        }       
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
           "Alacritty"
           // "foot"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition",
            "youtube-music": "youtube"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal",
            "youtube-music": "Music"
        }
    },
    "hyprland/window": {
       // "rewrite": {
       //     "(.*) - Brave": "$1",
       //     "(.*) - Chromium": "$1",
       //     "(.*) - Brave Search": "$1",
       //     "(.*) - Outlook": "$1",
       //     "(.*) Microsoft Teams": "$1",
       //     "(.*) - Vivaldi": "$1"
       // },
        // "max-length": 200,
        "separate-outputs": true
    },
    "group/quicklinks": {
        "orientation": "horizontal",
        "modules": [
            "custom/browser",
            "custom/filemanager",
         ]
    },
    "custom/browser": {
        "format": "’ē©",
        "on-click": "vivaldi",
        "tooltip": false
    },
    "custom/filemanager": {
        "format": "’ü╝",
        "on-click": "thunar",
        "tooltip": false
    },

    // Modules to Right.
    // Pulseaudio
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
        "format-muted": "’Ü® {format_source}",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć”", "’Ć© ", "’Ć© "]
        },
        "on-click": "pavucontrol"
    },



    // Bluetooth
    "bluetooth": {
        "format": "’Ŗō {status}",
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager"
    },

    // Battery
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "’Ś¦  {capacity}%",
        "format-plugged": "’ć”  {capacity}%",
        "format-alt": "{icon}  {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "]
    },

    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "’ć½   {signalStrength}%",
        "format-ethernet": "’×¢  {ifname}",
        "format-disconnected": "Disconnected",
        "tooltip-format": "’×¢ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "’×¢ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        // "on-click": "~/dotfiles/.settings/networkmanager.sh"
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory",
            "hyprland/language"
        ]
    },
    "custom/system": {
        "format": "Ņæ│",
        "tooltip": false
    },
    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "foot -e htop"
    }, 
    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "foot -e htop"
    },
    "memory": {
        "format": "/ M {}% ",
        "on-click": "foot -e htop"
    },
    "hyprland/language": {
        "format": "/ K {short}"
    },

    // Cliphist
    "custom/cliphist": {
        "format": "’ā¬",
        "on-click": "sleep 0.1 && clipman pick --tool wofi -T'--prompt=clipboard-history -i'",
        // "on-click-right": "sleep 0.1 && ",
        // "on-click-middle": "sleep 0.1 && ",
        "tooltip": false
    },

    // Idle Inhibator
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "’Åü",
            "deactivated": "’ĆŻ"
        },
        "on-click-right": "swaylock"        
    },

    // tray
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // START CLOCK FORMAT
        "format-alt": "{:%Y-%m-%d}"
        // END CLOCK FORMAT
    },

    // Power Menu
    "custom/exit": {
        "format": "’Ćæ",
        "on-click": "wlogout",
        "tooltip": false
    },

}

