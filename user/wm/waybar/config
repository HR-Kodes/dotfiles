{
    // Position TOP
    "layer": "top",
    // "margin-top": 14,
    "margin-bottom": 0,
    "layer": "top",
    "margin-left": 0,
    "margin-right": 0,    
    "spacing": 0,

    // Choose the order of the modules
    "modules-left": [
      "custom/appmenu",
      "wlr/taskbar",
      "group/quicklinks",
      "hyprland/window"
     ],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [
      "pulseaudio",
      "bluetooth",
      "battery",
      "network",
      // "group/hardware",
      "custom/cliphist",
      "idle_inhibitor",
      "tray",
      // "custom/exit",
      // "custom/ml4w-welcome",
      "clock"


      // "pulseaudio",
      // "clock",
      // "tray"
     ],

    // Modules configuration
    "custom/appmenu": {
        // START APPS LABEL
        "format": "Apps",
        // END APPS LABEL
        "on-click": "wofi --show drun -a -I",
        "tooltip": false
    },
    "hyprland/workspaces" : {
        // "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
	"on-scroll-up": "hyprctl dispatch workspace e+1",
	"on-scroll-down": "hyprctl dispatch workspace e-1",
        "format": "{}",
        "format-icons": {
	  "urgent": "яБк",
	  "focused": "яЖТ",
	  "default": "яДС"
         },
        "persistent-workspaces": {
            // START WORKSPACES
    "*": 5
            // END WORKSPACES
        }       
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
           "Alacritty"
	   // "foot"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal"
        }
    },
    "hyprland/window": {
       // "rewrite": {
       //     "(.*) - Brave": "$1",
       //     "(.*) - Chromium": "$1",
       //     "(.*) - Brave Search": "$1",
       //     "(.*) - Outlook": "$1",
       //     "(.*) Microsoft Teams": "$1",
       //     "(.*) - Vivaldi": "$1"
       // },
        // "max-length": 200,
        "separate-outputs": true
    },
    "group/quicklinks": {
        "orientation": "horizontal",
        "modules": [
            "custom/browser",
            "custom/filemanager",
         ]
    },
    "custom/browser": {
        "format": "яЙи",
        "on-click": "vivaldi",
        "tooltip": false
    },
    "custom/filemanager": {
        "format": "яБ╝",
        "on-click": "thunar",
        "tooltip": false
    },

    // Modules to Right.
    // Pulseaudio
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАи ", "яАи "]
        },
        "on-click": "pavucontrol"
    },



    // Bluetooth
    "bluetooth": {
        "format": "яКУ {status}",
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager"
    },

    // Battery
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "яЧз  {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{icon}  {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "]
    },

    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "яЗл   {signalStrength}%",
        "format-ethernet": "яЮЦ  {ifname}",
        "format-disconnected": "Disconnected",
        "tooltip-format": "яЮЦ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "яЗл  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "яЮЦ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        // "on-click": "~/dotfiles/.settings/networkmanager.sh"
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory",
            "hyprland/language"
        ]
    },
    "custom/system": {
        "format": "юС│",
        "tooltip": false
    },
    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "foot -e htop"
    }, 
    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "foot -e htop"
    },
    "memory": {
        "format": "/ M {}% ",
        "on-click": "foot -e htop"
    },
    "hyprland/language": {
        "format": "/ K {short}"
    },

    // Cliphist
    "custom/cliphist": {
        "format": "яГк",
        "on-click": "sleep 0.1 && clipman pick --tool wofi -T'--prompt=clipboard-history -i'",
        // "on-click-right": "sleep 0.1 && ",
        // "on-click-middle": "sleep 0.1 && ",
        "tooltip": false
    },

    // Idle Inhibator
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "яПБ",
            "deactivated": "яАг"
        },
        "on-click-right": "swaylock"        
    },

    // tray
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // START CLOCK FORMAT
        "format-alt": "{:%Y-%m-%d}"
        // END CLOCK FORMAT
    },



